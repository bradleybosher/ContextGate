# Provider selection: "mock" (default, hermetic) or "anthropic"
CONTEXTGATE_LLM_PROVIDER=mock

# Required only when CONTEXTGATE_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CONTEXTGATE_ANTHROPIC_MODEL=claude-opus-4-7

# Sensitivity filter mode
#   0 -> redact matches in-place as [REDACTED:<type>]
#   1 -> drop any doc that contains a detected secret
CONTEXTGATE_BLOCK_ON_SECRET=0

# Audit log destination (JSONL, one entry per request)
CONTEXTGATE_AUDIT_LOG=./audit.log

# Retrieval depth
CONTEXTGATE_TOP_K=5
